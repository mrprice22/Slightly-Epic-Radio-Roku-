<?xml version="1.0" encoding="UTF-8"?>

<component name="HomeScene" extends="Scene">
	<script type = "text/brightscript" uri = "pkg:/components/HomeScene.brs" />
	<script type = "text/brightscript" uri = "pkg:/components/Config.brs" />

	<children>
		<Video
			id = "Video"
			translation = "[0,0]"
			width = "1920"
			height = "1080"
			enableUI = "true"
			loop = "true" />

		<!-- Station artwork shown during playback -->
		<Poster
			id = "StationPoster"
			translation = "[560,190]"
			width = "800"
			height = "450"
			loadWidth = "800"
			loadHeight = "450"
			loadDisplayMode = "scaleToFit" />

		<!-- Now Playing info overlay -->
		<Rectangle
			id = "NowPlayingBar"
			translation = "[0,660]"
			width = "1920"
			height = "120"
			color = "0x000000CC"
			opacity = "0.85">
			<Label
				id = "NowPlayingLabel"
				height = "120"
				width = "1800"
				maxLines = "3"
				wrap = "true"
				text = ""
				translation = "[60,0]"
				vertAlign = "center"
				horizAlign = "center"
				font = "font:SmallBoldSystemFont"
				color = "0xFFFFFFFF" />
		</Rectangle>

		<Rectangle
			id = "BottomBar"
			translation = "[0,1080]"
			width = "1920"
			height = "335"
			color = "0x000000FF"
			opacity = "0.7">
			<RowList
				id = "RowList"
				itemComponentName = "RowListItems"
				translation = "[80,65]"
				numRows = "1"
				rowItemSize = "[[227,128]]"
				rowItemSpacing = "[[20,0]]"
				itemSize = "[1820,300]"
				rowFocusAnimationStyle = "floatingFocus">
			</RowList>
			<Label
				id="hudHint"
				height="50"
				width="400"
				text = "Press down to dismiss"
				translation="[760,10]"
				font = "font:SmallBoldSystemFont" />
		</Rectangle>
		<Animation
			id = "ShowBar"
			repeat = "false"
			duration = ".2"
			easeFunction = "linear">
			<Vector2DFieldInterpolator
				fieldToInterp = "BottomBar.translation"
				key = "[0,1]"
				keyValue = "[[0,1080],[0,745]]" />
		</Animation>
		<Animation
			id = "HideBar"
			repeat = "false"
			duration = ".2"
			easeFunction = "linear">
			<Vector2DFieldInterpolator
				fieldToInterp = "BottomBar.translation"
				key = "[0,1]"
				keyValue = "[[0,745],[0,1080]]" />
		</Animation>
		<Label
			id = "Hint"
			height = "50"
			width = "600"
			text = "Press UP to select other streams"
			font = "font:SmallBoldSystemFont"
			translation = "[1300,50]"
			visible = "false" />
		<Timer
			id = "Timer"
			repeat = "false"
			duration = "3" />
		<Timer
			id = "AdTimer"
			repeat = "true"
			duration = "1200" />
	</children>
</component>
